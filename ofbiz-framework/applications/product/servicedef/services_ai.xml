<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>AI demand forecast integration</description>
    <vendor>OFBiz</vendor>
    <version>1.0</version>

    <service name="predictDemandForProduct" default-entity-name="DemandForecast"
             engine="groovy" location="component://product/groovy/ai/PredictDemand.groovy"
             invoke="predictDemandForProduct" auth="true" export="true">
      <attribute name="productId" mode="IN" type="String" optional="false"/>
      <attribute name="horizonDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="forecastId" mode="OUT" type="String"/>
      <attribute name="avgDaily" mode="OUT" type="Double"/>
      <attribute name="total" mode="OUT" type="Double"/>
      <attribute name="runDate" mode="OUT" type="Timestamp"/>
    </service>

    <service name="predictDemandForProducts" default-entity-name="DemandForecast"
             engine="groovy" location="component://product/groovy/ai/PredictDemand.groovy"
             invoke="predictDemandForProducts" auth="true" export="true">
      <attribute name="productIds" mode="IN" type="List" optional="false"/>
      <attribute name="horizonDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="results" mode="OUT" type="List"/>
    </service>

    <service name="predictDemandForAllProducts" default-entity-name="DemandForecast"
             engine="groovy" location="component://product/groovy/ai/PredictDemand.groovy"
             invoke="predictDemandForAllProducts" auth="true" export="true">
      <attribute name="horizonDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="maxProducts" mode="IN" type="Integer" optional="true"/>
      <attribute name="results" mode="OUT" type="List"/>
    </service>

    <service name="enqueueDemandForecasts" default-entity-name="DemandForecast"
             engine="groovy" location="component://product/groovy/ai/PredictDemand.groovy"
             invoke="enqueueDemandForecasts" auth="true" export="true">
      <attribute name="horizonDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="maxProducts" mode="IN" type="Integer" optional="true"/>
    </service>

    <service name="enqueueDemandForecastsPersistent" default-entity-name="DemandForecast"
             engine="groovy" location="component://product/groovy/ai/PredictDemand.groovy"
             invoke="enqueueDemandForecastsPersistent" auth="true" export="true">
      <attribute name="horizonDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="maxProducts" mode="IN" type="Integer" optional="true"/>
    </service>

    <service name="exportDemandDataBundle"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportDemandDataBundle" auth="true" export="true">
      <attribute name="statusId" mode="IN" type="String" optional="true"/>
      <attribute name="fromDate" mode="IN" type="Timestamp" optional="true"/>
      <attribute name="toDate" mode="IN" type="Timestamp" optional="true"/>
      <attribute name="daysBack" mode="IN" type="Integer" optional="true"/>
    </service>

    <service name="exportDemandDataDelta"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportDemandDataDelta" auth="true" export="true">
      <attribute name="daysBack" mode="IN" type="Integer" optional="true"/>
    </service>

    <service name="exportOrderLinesForDemand"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportOrderLinesForDemand" auth="true" export="true">
      <attribute name="statusId" mode="IN" type="String" optional="true"/>
      <attribute name="fromDate" mode="IN" type="Timestamp" optional="true"/>
      <attribute name="toDate" mode="IN" type="Timestamp" optional="true"/>
      <attribute name="daysBack" mode="IN" type="Integer" optional="true"/>
    </service>

    <service name="exportProductsForDemand"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportProductsForDemand" auth="true" export="true">
    </service>

    <service name="exportProductFacilityForDemand"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportProductFacilityForDemand" auth="true" export="true">
    </service>

    <service name="exportInventoryItemsForDemand"
             engine="groovy" location="component://product/groovy/ai/ExportDemandData.groovy"
             invoke="exportInventoryItemsForDemand" auth="true" export="true">
    </service>

    <service name="getDemandForecastDashboard"
             engine="groovy" location="component://product/groovy/ai/DemandForecastDashboard.groovy"
             invoke="getDemandForecastDashboard" auth="true" export="true">
      <attribute name="productId" mode="IN" type="String" optional="true"/>
      <attribute name="evalDays" mode="IN" type="Integer" optional="true"/>
      <attribute name="forecastCount" mode="OUT" type="Long"/>
      <attribute name="lastRunDate" mode="OUT" type="Timestamp" optional="true"/>
      <attribute name="avgStockGap" mode="OUT" type="Double"/>
      <attribute name="maxStockGap" mode="OUT" type="Double"/>
      <attribute name="accuracyScore" mode="OUT" type="Double" optional="true"/>
      <attribute name="metrics" mode="OUT" type="Map" optional="true"/>
      <attribute name="riskLanes" mode="OUT" type="Map" optional="true"/>
      <attribute name="methodMix" mode="OUT" type="List" optional="true"/>
      <attribute name="evaluation" mode="OUT" type="Map" optional="true"/>
      <attribute name="topGaps" mode="OUT" type="List" optional="true"/>
      <attribute name="topDemand" mode="OUT" type="List" optional="true"/>
      <attribute name="latestRows" mode="OUT" type="List" optional="true"/>
      <attribute name="noHistoryRows" mode="OUT" type="List" optional="true"/>
      <attribute name="productFilter" mode="OUT" type="String" optional="true"/>
      <attribute name="demandChart" mode="OUT" type="List" optional="true"/>
      <attribute name="gapChart" mode="OUT" type="List" optional="true"/>
      <attribute name="timelineChart" mode="OUT" type="List" optional="true"/>
    </service>
</services>
